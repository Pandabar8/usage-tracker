---
import Layout from '../layouts/Layout.astro';
import RetentionPanel from '../components/RetentionPanel.tsx';
import {
  getRetention,
  isRetentionRisky,
  effectiveRetentionDays,
  RETENTION_TARGET_DAYS,
} from '../lib/settings';
import { scan } from '../lib/scan';
import { earliestClaudeTimestamp } from '../lib/aggregate';

export const prerender = false;

const info = getRetention();
const { records } = scan();
const retention = {
  cleanupPeriodDays: info.cleanupPeriodDays,
  effectiveDays: effectiveRetentionDays(info),
  protected: !isRetentionRisky(info),
  claudeStart: earliestClaudeTimestamp(records),
  targetDays: RETENTION_TARGET_DAYS,
};
---
<Layout title="Settings">
  <div class="top">
    <div>
      <h1>Settings</h1>
      <div class="sub">local · read-only except the protect action below</div>
    </div>
  </div>

  <div class="card" style="margin-bottom:16px">
    <h3>Theme</h3>
    <p class="hint">Refined dark. Light theme is out of scope for v1.</p>
  </div>

  <RetentionPanel client:load initial={retention} />
</Layout>
