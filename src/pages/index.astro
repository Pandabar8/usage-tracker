---
import Layout from '../layouts/Layout.astro';
import Dashboard from '../components/Dashboard.tsx';
import { scan } from '../lib/scan';
import { aggregate, claudeWindows } from '../lib/aggregate';
import { defaultPricing } from '../lib/pricing';

export const prerender = false;

const { records, codexQuota } = scan();
const rollups = aggregate(records, codexQuota, defaultPricing, claudeWindows(records, Date.now()));
---
<Layout>
  <Dashboard client:load initial={rollups} />
</Layout>
